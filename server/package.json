{
    "name": "mcp-server-for-revit",
    "version": "2.2.0",
    "description": "MCP server for interacting with Autodesk Revit through AI assistants like Claude",
    "main": "./build/index.js",
    "type": "module",
    "bin": {
        "mcp-server-for-revit": "./build/index.js"
    },
    "scripts": {
        "clean": "rimraf build",
        "prebuild": "npm run clean",
        "build": "node esbuild.config.mjs && node generate-tool-schemas.mjs && node deploy-addins.mjs",
        "build:check": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "build",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mathieucostudio-ui/MCP-REVIT.git"
    },
    "keywords": [
        "mcp",
        "revit",
        "autodesk",
        "claude",
        "ai",
        "bim",
        "architecture"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "bugs": {
        "url": "https://github.com/LuDattilo/revit-mcp-server/issues"
    },
    "homepage": "https://github.com/LuDattilo/revit-mcp-server#readme",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.7.0",
        "sql.js": "^1.14.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^22.13.10",
        "@types/sql.js": "^1.4.11",
        "esbuild": "^0.28.0",
        "rimraf": "^5.0.10",
        "typescript": "^5.8.2"
    }
}
